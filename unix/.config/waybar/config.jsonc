[
  {
    "layer": "top",
    "position": "top",
    "name": "main",

    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
      "custom/arch",
      "tray",
      "custom/spacer3",
      "custom/hypridle",
      "custom/updater",
      "custom/spacer3",
      "custom/spacer2",
      "hyprland/workspaces",
      "custom/spacer2",
      "custom/spacer3",
      "hyprland/submap",
      "hyprland/window",
    ],

    "modules-right": [
      "cpu",
      "temperature",
      "group/storage",
      "network#info",
      "custom/spacer1",
      "pulseaudio#input",
      "pulseaudio#output",
      "custom/spacer1",
      "keyboard-state",
      "custom/spacer1",
      "clock",
      "custom/notification",
      "custom/power",
    ],

    // Modules
    "disk": {
      "interval": 16,
      "format": "’āć {percentage_used}%",
      "tooltip": "{}",
      "tooltip-format": "Free {free}",
      "states": {
        "warning": 85,
        "critical": 95,
      },
    },

    "group/storage": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": "500",
        "transition-left-to-right": "true",
        "children-class": "drawer-child",
      },
      "modules": ["memory#ram", "memory#swap", "disk"],
    },

    "clock": {
      "interval": 1,
      "format": "ŅÖü {:%H:%M:%S  ŌĆēŅ¬░ %d.%m}",
      "tooltip-format": "{:%d.%m.%Y   Week %W}\n\n<tt><small>{calendar}</small></tt>",
      "calendar": {
        "mode": "month",
        "mode-mon-col": 3,
        "weeks-pos": "right",
        "on-scroll": 1,
        "format": {
          "months": "<span color='#cba6f7'><b>{}</b></span>",
          "days": "<span color='#cdd6f4'><b>{}</b></span>",
          "weeks": "<span color='#94e2d5'> W{}</span>",
          "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
          "today": "<span color='#f5e0dc'><b><u>{}</u></b></span>",
        },
      },
      "on-click": "brave --app=https://calendar.google.com",
    },

    "cpu": {
      "interval": 4,
      "format": "’ŗø {usage}%",
      "states": {
        "warning": 80,
        "critical": 95,
      },
    },

    "memory#ram": {
      "interval": 4,
      "format": "Ņ┐ģ {percentage}%",
      "states": {
        "warning": 80,
        "critical": 95,
      },
      "tooltip": "{}",
      "tooltip-format": "{used}/{total} GiB",
    },

    "memory#swap": {
      "interval": 16,
      "format": "¾░ŠĄ {swapPercentage}%",
      "tooltip": "{}",
      "tooltip-format": "{swapUsed}/{swapTotal}GiB",
    },

    "network#info": {
      "interval": 2,
      "format": "¾▒ś¢  Offline",
      "format-wifi": "{icon} {bandwidthDownBits}",
      "format-ethernet": "¾░łĆ {bandwidthDownBits}",
      "min-length": 11,
      "tooltip": "{}",
      "tooltip-format-wifi": "{ifname}\n{essid}\n{signalStrength}% \n{frequency} GHz\n¾░ćÜ {bandwidthDownBits}\n¾░ĢÆ {bandwidthUpBits}",
      "tooltip-format-ethernet": "{ifname}\n¾░ćÜ {bandwidthDownBits} \n¾░ĢÆ {bandwidthUpBits}",
      "format-icons": ["¾░ż½", "¾░ż¤", "¾░żó", "¾░żź", "¾░ż©"],
      "states": {
        "normal": 25,
      },
    },

    "hyprland/submap": {
      "always-on": true,
      "default-submap": "",
      "format": "{}",
      "format-RESIZE": "{}lol",
      "tooltip": false,
    },

    "hyprland/window": {
      "format": "{title}",
      "max-length": 48,
      "tooltip": false,
      "icon": true,
      "icon-size": 18,
    },

    "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "warp-on-scroll": false,
      "sort-by-number": true,
      "show-special": false,
      "on-click": "activate",
      "on-scroll-up": "hyprctl dispatch workspace e+1",
      "on-scroll-down": "hyprctl dispatch workspace e-1",
      "persistent-workspaces": {
        "*": 5,
      },
      "format": "{}{windows}",
      "format-window-separator": "",
      "window-rewrite-default": "’üÖ ",
      "window-rewrite": {
        "title<.*amazon.*>": " ’ē░ ",
        "title<.*reddit.*>": " ’Ŗü ",
        "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": " ŅØģ ",
        "class<zen>": " ¾░░Ę ",
        "class<waterfox|waterfox-bin>": " Ņ║ō ",
        "class<microsoft-edge>": " ’Ŗé ",
        "class<Chromium|Thorium|[Cc]hrome>": " ’ē© ",
        "class<brave-browser>": " ­¤”ü ",
        "class<tor browser>": " ’Ź▒ ",
        "class<firefox-developer-edition>": " ­¤”Ŗ ",
        "class<kitty|konsole>": " Ņ»å ",
        "class<kitty-dropterm>": " ’äĀ ",
        "class<com.mitchellh.ghostty>": "  Ņ×Ģ",
        "class<org.wezfurlong.wezterm>": "  Ņ¬ģ",
        "class<[Tt]hunderbird|[Tt]hunderbird-esr>": " ’Ź░ ",
        "class<eu.betterbird.Betterbird>": " ’Ź░ ",
        "title<.*gmail.*>": " ¾░Ŗ½ ",
        "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": " ŅłŚ ",
        "class<discord|[Ww]ebcord|Vesktop>": " ’ć┐ ",
        "title<.*whatsapp.*>": " ’ł▓ ",
        "title<.*zapzap.*>": " ’ł▓ ",
        "title<.*WasIstLos.*>": " ’ł▓ ",
        "title<.*messenger.*>": " ’ē¤ ",
        "title<.*facebook.*>": " ’éÜ ",
        "title<.*reddit.*>": " ’Ŗü ",
        "title<.*ChatGPT.*>": " ¾░Ü® ",
        "title<.*deepseek.*>": " ¾░Ü® ",
        "title<.*qwen.*>": " ¾░Ü® ",
        "class<subl>": " ¾░ģ│ ",
        "class<slack>": " ’åś ",
        "class<mpv>": " ’Ź« ",
        "class<celluloid|Zoom>": " ’ĆĮ ",
        "class<Cider>": " ¾░Äå ",
        "title<.*Picture-in-Picture.*>": " ’ö¼ ",
        "title<.*youtube.*>": " ’ģ¬ ",
        "class<vlc>": " ¾░Ģ╝ ",
        "title<.*cmus.*>": " ’Ćü ",
        "class<[Ss]potify>": " ’å╝ ",
        "class<virt-manager>": " ŅŁ╗ ",
        "class<.virt-manager-wrapped>": " ŅŁ╗ ",
        "class<virtualbox manager>": " ­¤ÆĮ ",
        "title<virtualbox>": " ­¤ÆĮ ",
        "class<remmina>": " ­¤¢ź’ĖÅ ",
        "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": " ¾░©× ",
        "class<dev.zed.Zed>": " ¾░Ąü",
        "class<codeblocks>": " ¾░ģ® ",
        "title<.*github.*>": " ’äō ",
        "class<mousepad>": " ’ģ£ ",
        "class<libreoffice-writer>": " ŅÜź ",
        "class<libreoffice-startcenter>": " ¾░Åå ",
        "class<libreoffice-calc>": " ’Ź╗ ",
        "title<.*nvim ~.*>": " ’Ź» ",
        "title<.*vim.*>": " Ņ¤ģ ",
        "title<.*nvim.*>": " Ņ¤ģ ",
        "title<.*figma.*>": " ŅĮć ",
        "title<.*jira.*>": " ŅØ£ ",
        "class<jetbrains-idea>": " Ņ×Ą ",
        "class<obs|com.obsproject.Studio>": " Ņ«¦ ",
        "class<polkit-gnome-authentication-agent-1>": " ¾░Æā ",
        "class<nwg-look>": " ŅŁÆ ",
        "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": " ¾▒Ī½ ",
        "class<steam>": " ’åČ ",
        "class<thunar|nemo>": " ¾░Ø░ ",
        "class<Gparted>": " ’āć",
        "class<gimp>": " ’īĖ ",
        "class<emulator>": " ­¤ō▒ ",
        "class<android-studio>": " ’ģ╗ ",
        "class<org.pipewire.Helvum>": " ¾░ōā",
        "class<localsend>": " ’ćĀ",
        "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": " ¾░╣ø",
      },
      "disable-scroll-wraparound": true,
      "smooth-scrolling-threshold": 4,
      "enable-bar-scroll": true,
      "special-visible-only": false,
    },

    "pulseaudio#output": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{icon}’Ŗö {volume}%",
      "format-source-muted": "{volume}",
      "format-icons": {
        "headphone": "’Ćź",
        "hands-free": "’Ćź",
        "headset": "’Ćź",
        "phone": "’éĢ",
        "portable": "’éĢ",
        "car": "’å╣",
        "default": ["’Ć¦", "’Ć©"],
      },
      "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
      "on-click": "pwvucontrol",
      "tooltip": true,
      "scroll-step": 5,
    },

    "pulseaudio#input": {
      "format": "Ņ┤ā {icon} {format_source}%",
      "format-source": "{volume}",
      "format-source-muted": "{volume}",
      "on-scroll-up": "sh -c 'vol=$(pactl get-source-volume @DEFAULT_SOURCE@ | grep -oP \"\\d+(?=%)\" | head -1); if [ \"$vol\" -lt 100 ]; then pactl set-source-volume @DEFAULT_SOURCE@ +5%; fi'",
      "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%",
      "max-volume": "100",
      "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
      "on-click": "pwvucontrol",
      "tooltip-format": "{source_desc}",
    },

    "temperature": {
      "critical-threshold": 90,
      "interval": 4,
      "format": "{icon} {temperatureC}┬░",
      "format-icons": ["’ŗŗ", "’ŗŖ", "’ŗē", "’ŗł", "’ŗć"],
      "tooltip": false,
    },

    "tray": {
      "icon-size": 17,
      "spacing": 8,
    },

    "custom/spacer1": {
      "format": " \\ ",
      "tooltip": false,
    },

    "custom/spacer2": {
      "format": " ",
      "tooltip": false,
    },

    "custom/spacer3": {
      "format": " // ",
      "tooltip": false,
    },

    "custom/arch": {
      "format": "¾░Żć",
      "tooltip": "Arch Linux",
      "on-click": "rofi -theme ~/.config/rofi/config.rasi -show drun",
    },

    "keyboard-state": {
      "numlock": true,
      "capslock": true,
      "format": "{name} {icon}",
      "format-icons": {
        "locked": "’ĆŻ",
        "unlocked": "’é£",
      },
    },

    "custom/power": {
      "format": "ŌÅ╗ ",
      "tooltip": true,
      "tooltip-format": "Power Menu",
      "on-click": "wlogout -s -b 6 -T 600 -B 600",
    },

    "custom/notification": {
      "tooltip": false,
      "format": "{} {icon}",
      "format-icons": {
        "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
        "none": "’éó",
        "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
        "dnd-none": "’ćĘ",
        "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
        "inhibited-none": "’éó",
        "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
        "dnd-inhibited-none": "’ćĘ",
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true,
    },

    "custom/updater": {
      "format": "’ĆÖ {}",
      "exec": "checkupdates | wc -l",
      "exec-if": "[[ $(checkupdates | wc -l) ]]",
      "interval": 43200, // (Arch Linux will try to check 12 hrs interval only
      "on-click": "$HOME/.config/hypr/scripts/Distro_update.sh",
      "tooltip": true,
      "tooltip-format": "Left Click: Update System\nArch (w/ notification)\nclick to update",
    },

    // Hypridle inhibitor
    "custom/hypridle": {
      "format": "¾▒½Ś ",
      "return-type": "json",
      "escape": true,
      "exec-on-event": true,
      "interval": 60,
      "exec": "$HOME/.config/hypr/scripts/Hypridle.sh status",
      "on-click": "$HOME/.config/hypr/scripts/Hypridle.sh toggle",
      "on-click-right": "hyprlock",
    },
  },
]
